{
  "name": "vscode-copilot-openai-proxy",
  "displayName": "GitHub Copilot OpenAI Proxy",
  "description": "Expose GitHub Copilot / VS Code Language Model API models through a local OpenAI-compatible HTTP API.",
  "version": "1.0.0",
  "publisher": "ByteSeekerPro",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ByteSeekerPro/vscode-copilot-openai-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/ByteSeekerPro/vscode-copilot-openai-proxy/issues"
  },
  "homepage": "https://github.com/ByteSeekerPro/vscode-copilot-openai-proxy#readme",
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "AI",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "OpenAI",
    "LLM",
    "Language Model",
    "AI",
    "API",
    "Bridge",
    "VS Code",
    "Language Model API",
    "OpenAI-compatible"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-copilot-openai-proxy.openSettings",
        "title": "GitHub Copilot OpenAI Proxy: Open Settings"
      },
      {
        "command": "vscode-copilot-openai-proxy.showCallHistory",
        "title": "GitHub Copilot OpenAI Proxy: Show Call History"
      },
      {
        "command": "vscode-copilot-openai-proxy.clearCallHistory",
        "title": "GitHub Copilot OpenAI Proxy: Clear Call History"
      },
      {
        "command": "vscode-copilot-openai-proxy.showSessionMetrics",
        "title": "GitHub Copilot OpenAI Proxy: Show Session Metrics"
      }
    ],
    "configuration": {
      "title": "GitHub Copilot OpenAI Proxy",
      "properties": {
        "vscode-copilot-openai-proxy.port": {
          "type": "integer",
          "default": 9090,
          "minimum": 1,
          "maximum": 65535,
          "description": "Local HTTP API server port."
        },
        "vscode-copilot-openai-proxy.callHistoryRetentionDays": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "description": "Number of days to keep call history records. Expired entries are cleaned up automatically."
        },
        "vscode-copilot-openai-proxy.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the local proxy server when the extension activates."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-copilot-openai-proxy-sidebar",
          "title": "Copilot OpenAI Proxy",
          "icon": "$(symbol-interface)"
        }
      ]
    },
    "views": {
      "vscode-copilot-openai-proxy-sidebar": [
        {
          "id": "vscode-copilot-openai-proxy-webview",
          "type": "webview",
          "name": "Copilot OpenAI Proxy",
          "icon": "$(symbol-interface)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "tsup src/extension.ts --external vscode --format cjs --minify --clean --out-dir out",
    "package": "npx vsce package",
    "watch": "tsup src/extension.ts --external vscode --format cjs --watch --out-dir out",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run bundle",
    "test:compat": "node scripts/test-compat.mjs"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vscode/test-electron": "^2.3.9",
    "cors": "^2.8.5",
    "eslint": "^8.56.0",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@vscode-elements/elements": "^2.5.1",
    "@vscode/codicons": "^0.0.40"
  },
  "extensionDependencies": [
    "github.copilot-chat"
  ]
}
